{
  "name": "@namcv/lumina",
  "version": "0.2.8",
  "description": "Illuminate your codebase — auto-generate source maps and architecture context for Claude Code",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "lumina": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "lumina",
    "claude-code",
    "source-map",
    "architecture",
    "react",
    "nestjs",
    "dependency-graph",
    "code-analysis"
  ],
  "author": "namcv",
  "repository": {
    "type": "git",
    "url": "https://github.com/namcv/lumina.git"
  },
  "homepage": "https://github.com/namcv/lumina#readme",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ignore": "^5.3.0",
    "picocolors": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
